---
import { locales, localeNames, type Locale } from '../i18n/config';
import { localizePath } from '../i18n/utils';

interface Props {
  /** Active locale. */
  locale: Locale;
  /** Locale-independent path of the current page, e.g. "" or "bcx/intro". */
  path: string;
}

const { locale, path } = Astro.props;
---

<div class="flex items-center gap-1 rounded-full border border-bc-border bg-bc-surface/60 p-1">
  {
    locales.map((l) => (
      <a
        href={localizePath(path, l)}
        hreflang={l}
        data-locale={l}
        aria-current={l === locale ? 'true' : undefined}
        class:list={[
          'rounded-full px-3 py-1 text-sm transition-colors',
          l === locale
            ? 'bg-bc-pink text-bc-bg font-semibold'
            : 'text-bc-muted hover:text-bc-text',
        ]}
      >
        {localeNames[l] ?? l}
      </a>
    ))
  }
</div>
