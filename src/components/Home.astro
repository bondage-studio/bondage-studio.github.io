---
import type { Locale } from '../i18n/config';
import { getTranslations } from '../i18n/utils';
import type { NavSection } from '../lib/nav';

interface Props {
  locale: Locale;
  sections: NavSection[];
}

const { locale, sections } = Astro.props;
const t = getTranslations(locale);

// Each card links to a section's landing page, falling back to its first page.
const cards = sections
  .map((s) => ({
    label: s.label,
    description: s.description,
    href: s.href ?? s.items[0]?.href,
  }))
  .filter((c) => !!c.href);
---

<div class="py-12 sm:py-16">
  <p
    class="mb-4 inline-block rounded-full border border-bc-border bg-bc-surface/60 px-4 py-1 text-sm tracking-widest text-bc-purple-soft uppercase"
  >
    {t('hero.eyebrow')}
  </p>
  <h1 class="max-w-3xl text-4xl font-extrabold leading-tight sm:text-5xl">
    <span class="bc-gradient-text">{t('hero.title')}</span>
  </h1>
  <p class="mt-5 max-w-2xl text-lg text-bc-muted">{t('hero.subtitle')}</p>

  <div class="mt-10 grid gap-5 sm:grid-cols-2">
    {
      cards.map((c) => (
        <a
          href={c.href}
          class="group rounded-2xl border border-bc-border bg-bc-surface/50 p-6 transition-all hover:-translate-y-1 hover:border-bc-pink hover:shadow-[var(--shadow-glow)]"
        >
          <h2 class="text-xl font-semibold text-bc-text group-hover:text-bc-pink">
            {c.label}
          </h2>
          {c.description && (
            <p class="mt-2 text-sm text-bc-muted">{c.description}</p>
          )}
          <span class="mt-4 inline-block text-sm font-medium text-bc-cyan">
            {t('landing.readMore')} →
          </span>
        </a>
      ))
    }
  </div>
</div>