---
/**
 * A localized "install this userscript" guide.
 *
 * Authors use it from any `.mdx` doc — no import is needed, it is injected into
 * the MDX scope by the docs route (src/pages/[...slug].astro), so plain:
 *
 *   <UserscriptInstall url="https://example.com/Script.user.js" name="My Script" />
 *
 * just works. `url` is required; `name` and `manager` are optional. All copy
 * lives in the central i18n table (src/i18n/ui.ts, `userscript.*` keys) and is
 * localized from the current route; markup is styled by `.bc-userscript*` in
 * global.css.
 */
import { defaultLocale, isLocale, type Locale } from '../i18n/config';
import { getTranslations } from '../i18n/utils';

interface Props {
  url: string;
  name?: string;
  manager?: string;
}

const { url, name, manager: managerProp } = Astro.props;

const current = Astro.currentLocale;
const locale: Locale = isLocale(current ?? '') ? (current as Locale) : defaultLocale;
const t = getTranslations(locale);

const manager = managerProp?.trim() || 'Tampermonkey';
const trimmedName = name?.trim() || undefined;
const isTampermonkey = manager.toLowerCase() === 'tampermonkey';

const fill = (template: string, tokens: Record<string, string>) =>
  template.replace(/\{(\w+)\}/g, (m, k) => (k in tokens ? tokens[k] : m));

const esc = (s: string) =>
  s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');

// Tokens hold already-safe HTML, used with set:html for descriptions.
const tokens: Record<string, string> = {
  name: trimmedName ? esc(trimmedName) : '',
  manager: esc(manager),
  managerLink: isTampermonkey
    ? `<a href="https://www.tampermonkey.net/" rel="noopener">${esc(manager)}</a>`
    : esc(manager),
  install: `<strong>${esc(t('userscript.installWord'))}</strong>`,
};

const installTitle = trimmedName
  ? fill(t('userscript.installTitleNamed'), tokens)
  : t('userscript.installTitle');
const button = trimmedName
  ? fill(t('userscript.button'), tokens)
  : t('userscript.buttonGeneric');
const managerDesc = fill(t('userscript.managerDesc'), tokens);
const confirmDesc = fill(t('userscript.confirmDesc'), tokens);
---

<div class="bc-userscript">
  <ol class="bc-userscript-steps">
    <li>
      <strong>{t('userscript.managerTitle')}</strong>
      <p set:html={managerDesc} />
    </li>
    <li>
      <strong>{installTitle}</strong>
      <p>{t('userscript.installDesc')}</p>
      <p>
        <a class="bc-userscript-btn" href={url} rel="noopener">{button}</a>
      </p>
      <p class="bc-userscript-link">
        <span>{t('userscript.linkLabel')}</span> <code>{url}</code>
      </p>
    </li>
    <li>
      <strong>{t('userscript.confirmTitle')}</strong>
      <p set:html={confirmDesc} />
    </li>
  </ol>
</div>