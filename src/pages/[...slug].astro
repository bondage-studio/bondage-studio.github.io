---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import { locales, defaultLocale, type Locale } from '../i18n/config';
import { parseDocId } from '../i18n/utils';
import { getNav } from '../lib/nav';
import BaseLayout from '../layouts/BaseLayout.astro';
import Sidebar from '../components/Sidebar.astro';
import Home from '../components/Home.astro';

type Entry = CollectionEntry<'docs'>;

type PageProps =
  | { kind: 'home'; locale: Locale; urlPath: '' }
  | { kind: 'doc'; locale: Locale; urlPath: string; entry: Entry };

export async function getStaticPaths() {
  const slugFor = (locale: Locale, urlPath: string) => {
    const base = locale === defaultLocale ? '' : locale;
    const joined = [base, urlPath].filter(Boolean).join('/');
    // Catch-all param: undefined renders the index route ("/").
    return joined || undefined;
  };

  const paths: Array<{ params: { slug?: string }; props: PageProps }> = [];

  // Homepage, one per locale.
  for (const locale of locales) {
    paths.push({
      params: { slug: slugFor(locale, '') },
      props: { kind: 'home', locale, urlPath: '' },
    });
  }

  // Docs: group all entries by their locale-independent url path, then emit one
  // route per (locale, path). Missing translations fall back to the default
  // locale's entry so every page exists in every language.
  const docs = await getCollection('docs');
  const byPath = new Map<string, Partial<Record<Locale, Entry>>>();
  for (const entry of docs) {
    const { locale, urlPath } = parseDocId(entry.id);
    if (!urlPath) continue; // a bare "<locale>/index" would collide with home
    const group = byPath.get(urlPath) ?? {};
    group[locale] = entry;
    byPath.set(urlPath, group);
  }

  for (const [urlPath, group] of byPath) {
    for (const locale of locales) {
      const entry = group[locale] ?? group[defaultLocale];
      if (!entry) continue; // no localized and no English source → skip
      paths.push({
        params: { slug: slugFor(locale, urlPath) },
        props: { kind: 'doc', locale, urlPath, entry },
      });
    }
  }

  return paths;
}

const props = Astro.props as PageProps;
const Content =
  props.kind === 'doc' ? (await render(props.entry)).Content : null;

const sections = await getNav(props.locale);
const currentPath = props.kind === 'doc' ? props.urlPath : '';

const title = props.kind === 'doc' ? props.entry.data.title : 'Bondage Studio';
const description =
  props.kind === 'doc' ? props.entry.data.description : undefined;
---

<BaseLayout
  title={title}
  description={description}
  locale={props.locale}
  path={currentPath}
>
  <div
    class="mx-auto flex w-full max-w-7xl flex-col px-4 sm:px-6 lg:flex-row lg:gap-10"
  >
    <Sidebar
      locale={props.locale}
      sections={sections}
      currentPath={currentPath}
    />

    <div class="min-w-0 flex-1">
      {props.kind === 'home' && <Home locale={props.locale} sections={sections} />}

      {
        props.kind === 'doc' && Content && (
          <article class="max-w-3xl py-10 lg:py-12">
            <header class="mb-8 border-b border-bc-border/70 pb-6">
              <h1 class="bc-gradient-text text-4xl font-extrabold">
                {props.entry.data.title}
              </h1>
              {props.entry.data.description && (
                <p class="mt-3 text-lg text-bc-muted">
                  {props.entry.data.description}
                </p>
              )}
            </header>
            <div class="bc-prose">
              <Content />
            </div>
          </article>
        )
      }
    </div>
  </div>
</BaseLayout>
